APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=3000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=agent_flow
POSTGRES_USER=agent_flow
POSTGRES_PASSWORD=agent_flow_dev
DATABASE_URL=postgresql+asyncpg://agent_flow:agent_flow_dev@postgres:5432/agent_flow

REDIS_HOST=redis
REDIS_PORT=6380
REDIS_URL=redis://redis:6379/0

STORAGE_DIR=/data/uploads
SECRET_ENCRYPTION_KEY=dev-only-change-me-32-bytes-minimum
MOCK_USER_ID=1
AUTH_MODE=mock
API_BEARER_TOKEN=
DEFAULT_MODEL_PROVIDER=openai
MAX_UPLOAD_BYTES=10485760
ALLOWED_UPLOAD_CONTENT_TYPES=text/plain,text/markdown,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document

OPENAI_API_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
